---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getUi, type Lang } from "../i18n/ui";

interface Props {
  lang?: Lang;
  alt?: string;
}
const { lang = "en", alt } = Astro.props;
const t = getUi(lang);

const base = import.meta.env.BASE_URL;
const home = lang === "es" ? `${base}es/` : base;
const blog = `${home}blog`;
const path = Astro.url.pathname;
const onBlog = path.startsWith(`${base}blog`) || path.startsWith(`${base}es/blog`);

const link = (active: boolean) =>
  active
    ? "text-sm text-surface-900 font-medium"
    : "text-sm text-surface-600 hover:text-surface-900 transition-colors";
---

<nav class="sticky top-0 z-50 bg-ivory/90 backdrop-blur-sm border-b border-surface-200/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href={home} class="flex items-center gap-2">
        <img src="/favicon.svg" class="w-7 h-7" alt="Hoja" />
        <span class="text-base text-surface-900 font-brand font-bold">Hoja</span>
      </a>

      <div class="hidden md:flex items-center gap-7">
        <a href={`${home}#services`} class={link(false)}>{t.nav.services}</a>
        <a href={`${home}#technologies`} class={link(false)}>{t.nav.technologies}</a>
        <a href={`${home}#contact`} class={link(false)}>{t.nav.contact}</a>
        <a href={blog} class={link(onBlog)} aria-current={onBlog ? "page" : undefined}>{t.nav.blog}</a>
        {alt && <LanguageSwitcher lang={lang} alt={alt} />}
      </div>

      <button
        id="menu-btn"
        class="md:hidden p-2 text-surface-600 hover:text-surface-900"
        aria-label={t.nav.menu}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-open" class="w-5 h-5 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-3 border-t border-surface-200/50 mt-2 pt-3">
      <div class="flex flex-col gap-2">
        <a href={`${home}#services`} class="text-sm text-surface-600 hover:text-surface-900 py-2">{t.nav.services}</a>
        <a href={`${home}#technologies`} class="text-sm text-surface-600 hover:text-surface-900 py-2">{t.nav.technologies}</a>
        <a href={`${home}#contact`} class="text-sm text-surface-600 hover:text-surface-900 py-2">{t.nav.contact}</a>
        <a href={blog} class={`py-2 ${link(onBlog)}`} aria-current={onBlog ? "page" : undefined}>{t.nav.blog}</a>
        {alt && <div class="pt-2"><LanguageSwitcher lang={lang} alt={alt} /></div>}
      </div>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuOpen = document.getElementById("menu-open");
  const menuClose = document.getElementById("menu-close");

  const setOpen = (open: boolean) => {
    mobileMenu?.classList.toggle("hidden", !open);
    menuOpen?.classList.toggle("hidden", open);
    menuClose?.classList.toggle("hidden", !open);
    menuBtn?.setAttribute("aria-expanded", String(open));
  };

  menuBtn?.addEventListener("click", () => {
    setOpen(mobileMenu?.classList.contains("hidden") ?? false);
  });
  mobileMenu?.querySelectorAll("a").forEach((linkEl) => {
    linkEl.addEventListener("click", () => setOpen(false));
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !mobileMenu?.classList.contains("hidden")) setOpen(false);
  });
</script>
