---
---

<nav class="sticky top-0 z-50 bg-ivory/90 backdrop-blur-sm border-b border-surface-200/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2">
        <img src="/favicon.svg" class="w-7 h-7" alt="Hoja" />
        <span class="text-base text-surface-900 font-brand font-bold">Hoja</span>
      </a>

      <div class="hidden md:flex items-center gap-7">
        <a href="#services" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">Services</a>
        <a href="#about" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">About</a>
        <a href="#technologies" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">Technologies</a>
        <a href="#contact" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">Contact</a>
      </div>

      <button id="menu-btn" class="md:hidden p-2 text-surface-600 hover:text-surface-900" aria-label="Toggle menu">
        <svg id="menu-open" class="w-5 h-5 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-3 border-t border-surface-200/50 mt-2 pt-3">
      <div class="flex flex-col gap-2">
        <a href="#services" class="text-sm text-surface-600 hover:text-surface-900 py-2">Services</a>
        <a href="#about" class="text-sm text-surface-600 hover:text-surface-900 py-2">About</a>
        <a href="#technologies" class="text-sm text-surface-600 hover:text-surface-900 py-2">Technologies</a>
        <a href="#contact" class="text-sm text-surface-600 hover:text-surface-900 py-2">Contact</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuOpen = document.getElementById("menu-open");
  const menuClose = document.getElementById("menu-close");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    menuOpen?.classList.toggle("hidden");
    menuClose?.classList.toggle("hidden");
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      menuOpen?.classList.remove("hidden");
      menuClose?.classList.add("hidden");
    });
  });
</script>