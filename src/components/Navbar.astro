---
// Mobile menu toggle (client-side interactivity)
---

<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-surface-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-full bg-brand-600 flex items-center justify-center">
          <img src="/logo.svg" class="w-5 h-5 text-white" alt="Hoja" />
        </div>
        <span class="text-lg font-semibold text-surface-900 tracking-tight">Hoja</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">Services</a>
        <a href="#about" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">About</a>
        <a href="#contact" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">Contact</a>
        <a href="#contact" class="text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 px-4 py-2 rounded-lg transition-colors">
          Get in Touch
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden p-2 rounded-lg text-surface-600 hover:bg-surface-100 transition-colors" aria-label="Toggle menu">
        <svg id="menu-open" class="w-6 h-6 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1 pt-2">
        <a href="#services" class="text-sm text-surface-600 hover:text-surface-900 px-3 py-2.5 rounded-lg hover:bg-surface-50 transition-colors">Services</a>
        <a href="#about" class="text-sm text-surface-600 hover:text-surface-900 px-3 py-2.5 rounded-lg hover:bg-surface-50 transition-colors">About</a>
        <a href="#contact" class="text-sm text-surface-600 hover:text-surface-900 px-3 py-2.5 rounded-lg hover:bg-surface-50 transition-colors">Contact</a>
        <a href="#contact" class="text-sm font-medium text-center text-white bg-brand-600 hover:bg-brand-700 px-4 py-2.5 rounded-lg transition-colors mt-2">
          Get in Touch
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuOpen = document.getElementById("menu-open");
  const menuClose = document.getElementById("menu-close");

  menuBtn?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    menuOpen?.classList.toggle("hidden");
    menuClose?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      menuOpen?.classList.remove("hidden");
      menuClose?.classList.add("hidden");
    });
  });
</script>