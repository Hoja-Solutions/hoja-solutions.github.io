---
const columns = [
  {
    title: "Services",
    links: [
      { label: "AI Strategy", href: "#services" },
      { label: "Machine Learning", href: "#services" },
      { label: "Custom Software", href: "#services" },
      { label: "Data Engineering", href: "#services" },
      { label: "MLOps & Deployment", href: "#services" },
      { label: "Consulting & Training", href: "#services" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "#about" },
      { label: "Contact", href: "#contact" },
    ],
  },
  {
    title: "Connect",
    links: [
      { label: "LinkedIn", href: "https://linkedin.com/company/hoja-solutions", external: true },
      { label: "GitHub", href: "https://github.com/hoja-solutions", external: true },
      { label: "X / Twitter", href: "https://x.com/hoja_solutions", external: true },
    ],
  },
];
---

<footer class="bg-white border-t border-surface-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 lg:gap-16">
      {columns.map((col) => (
        <div>
          <h4 class="text-sm font-semibold text-surface-900 mb-4">{col.title}</h4>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  {link.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
                  class="text-sm text-surface-500 hover:text-surface-900 transition-colors inline-flex items-center gap-1"
                >
                  {link.label}
                  {link.external && (
                    <svg class="w-3 h-3 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-surface-200 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-full bg-brand-600 flex items-center justify-center">
          <img src="/logo.svg" class="w-4 h-4 text-white" alt="Hoja" />
        </div>
        <span class="text-sm font-medium text-surface-700">Hoja</span>
      </div>
      <p class="text-sm text-surface-400">
        &copy; {new Date().getFullYear()} Hoja. All rights reserved.
      </p>
    </div>
  </div>
</footer>