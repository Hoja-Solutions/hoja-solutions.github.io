---
import { getUi, type Lang } from "../i18n/ui";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = getUi(lang);
const base = import.meta.env.BASE_URL;
const home = lang === "es" ? `${base}es/` : base;

const columns = [
  {
    title: t.footer.services,
    links: t.services.items.map((s) => ({ label: s.title, href: `${home}#services`, external: false })),
  },
  {
    title: t.footer.company,
    links: [
      { label: t.footer.blog, href: `${home}blog`, external: false },
      { label: t.footer.rss, href: `${home}rss.xml`, external: false },
      { label: t.footer.terms, href: `${home}terms-and-policies`, external: false },
    ],
  },
  {
    title: t.footer.connect,
    links: [
      { label: "LinkedIn", href: "https://linkedin.com/company/hoja-solutions", external: true },
      { label: "GitHub", href: "https://github.com/hoja-solutions", external: true },
      { label: "Hugging Face", href: "https://huggingface.co/hoja-solutions", external: true },
    ],
  },
];
---

<footer class="bg-ivory border-t border-surface-200/50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-10 sm:py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8">
      {columns.map((col) => (
        <div>
          <h4 class="text-xs font-medium text-surface-900 uppercase tracking-wider mb-3">{col.title}</h4>
          <ul class="space-y-2">
            {col.links.map((linkItem) => (
              <li>
                <a
                  href={linkItem.href}
                  {...(linkItem.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  class="text-sm text-surface-600 hover:text-surface-900 transition-colors inline-flex items-center gap-1"
                >
                  {linkItem.label}
                  {linkItem.external && (
                    <svg class="w-3 h-3 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 pt-6 border-t border-surface-200/50 flex flex-col sm:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <img src="/favicon.svg" class="w-5 h-5" alt="Hoja" />
        <span class="text-sm text-surface-700 font-brand font-bold">Hoja</span>
      </div>
      <p class="text-xs text-surface-500">
        &copy; {new Date().getFullYear()} <span class="font-brand font-bold">Hoja</span>. {t.footer.rights}
      </p>
    </div>
  </div>
</footer>
