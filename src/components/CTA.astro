---
// Paste the ID from your Formspree endpoint (the part after /f/).
const FORMSPREE_ID = import.meta.env.PUBLIC_FORMSPREE_ID || "mojgklva";
const action = `https://formspree.io/f/${FORMSPREE_ID}`;

const inputClass =
  "w-full text-sm px-3.5 py-2.5 rounded-md border border-surface-300 bg-ivory text-surface-800 placeholder:text-surface-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 transition-colors";

// Illustration: a sprout whose growth becomes a paper plane's flight.
let illo = "";
illo += `<line x1="52" y1="254" x2="150" y2="254" stroke="#b5ada0" stroke-width="1.6"/>`;
illo += `<path d="M 100 254 C 95 222 106 186 100 152" fill="none" stroke="#4d9622" stroke-width="2.4"/>`;
illo += `<path d="M 100 174 C 74 172 61 153 67 141 C 82 143 99 156 100 174 Z" fill="#8fd042" stroke="#4d9622" stroke-width="1"/>`;
illo += `<path d="M 100 152 C 126 150 139 131 133 119 C 118 121 101 134 100 152 Z" fill="#6bb82d" stroke="#4d9622" stroke-width="1"/>`;
illo += `<path d="M 150 170 C 185 200 244 194 274 124" fill="none" stroke="#b5ada0" stroke-width="1.6" stroke-dasharray="3 6" stroke-linecap="round"/>`;
illo += `<polygon points="346,84 280,106 306,109" fill="#d7f0a5" stroke="#4d9622" stroke-width="1.6" stroke-linejoin="round"/>`;
illo += `<polygon points="346,84 306,109 312,140" fill="#8fd042" stroke="#4d9622" stroke-width="1.6" stroke-linejoin="round"/>`;
---

<section id="contact" class="bg-ivory-dark border-t border-surface-200/40 pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <p class="text-xs font-medium text-brand-600 uppercase tracking-wider mb-3">Contact</p>
        <h2 class="text-2xl sm:text-3xl font-semibold text-surface-900 tracking-tight">
          Tell us about your project
        </h2>
        <p class="mt-6 text-base text-surface-600 leading-relaxed">
          Tell us what you are building. We will get back to you within one business day and be honest about whether we can help.
        </p>

        <form id="contact-form" action={action} method="POST" class="mt-8 space-y-4">
          <div>
            <label for="name" class="sr-only">Name</label>
            <input id="name" name="name" type="text" required autocomplete="name" placeholder="Your name" class={inputClass} />
          </div>
          <div>
            <label for="email" class="sr-only">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@company.com" class={inputClass} />
          </div>
          <div>
            <label for="message" class="sr-only">Message</label>
            <textarea id="message" name="message" required rows="4" placeholder="What are you building?" class={`${inputClass} resize-y`}></textarea>
          </div>

          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />
          <input type="hidden" name="_subject" value="New inquiry from hoja.solutions" />

          <div class="flex flex-col sm:flex-row sm:items-center gap-3 pt-1">
            <button
              type="submit"
              id="submit-btn"
              class="text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-md transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Send message
            </button>
            <a href="https://calendly.com/joseesparza/30min" target="_blank" rel="noopener noreferrer" class="text-sm text-surface-600 hover:text-surface-900 transition-colors">
              or schedule a call
            </a>
          </div>

          <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
        </form>
      </div>

      <div class="flex justify-center lg:justify-end">
        <svg viewBox="0 0 420 300" width="100%" height="100%" class="w-full max-w-md" role="img" aria-label="A sprout growing into a paper plane in flight" set:html={illo} />
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  if (form && status && btn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "";
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = "Sending...";
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.reset();
          status.className = "text-sm text-brand-700";
          status.textContent = "Thanks. We will get back to you within one business day.";
        } else {
          const data = await res.json().catch(() => null);
          status.className = "text-sm text-red-600";
          status.textContent =
            data?.errors?.[0]?.message ??
            "Something went wrong. Please try again, or schedule a call above.";
        }
      } catch {
        status.className = "text-sm text-red-600";
        status.textContent = "Network error. Please try again in a moment.";
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  }
</script>
