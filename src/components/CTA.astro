<section id="contact" class="bg-ivory-dark border-t border-surface-200/40 pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <p class="text-xs font-medium text-brand-600 uppercase tracking-wider mb-3">Contact</p>
        <h2 class="text-2xl sm:text-3xl font-semibold text-surface-900 tracking-tight">
          Tell us about your project
        </h2>
        <p class="mt-6 text-base text-surface-600 leading-relaxed">
          We respond within one business day. Tell us what you are building. We will say yes or no.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="mailto:contact@hoja.solutions" class="text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-md transition-colors text-center">
            Email Us
          </a>
          <a href="https://cal.com/hoja-solutions" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-surface-700 hover:text-surface-900 px-5 py-2.5 rounded-md transition-colors border border-surface-300 hover:border-surface-400 text-center">
            Schedule a Call
          </a>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="isometric-scene">
          <!-- Cube 1: Small -->
          <div class="iso-cube cube-1" style="--size: 48px;">
            <div class="face front"></div>
            <div class="face back"></div>
            <div class="face right"></div>
            <div class="face left"></div>
            <div class="face top"></div>
            <div class="face bottom"></div>
          </div>

          <!-- Cube 2: Medium -->
          <div class="iso-cube cube-2" style="--size: 72px;">
            <div class="face front"></div>
            <div class="face back"></div>
            <div class="face right"></div>
            <div class="face left"></div>
            <div class="face top"></div>
            <div class="face bottom"></div>
          </div>

          <!-- Cube 3: Large -->
          <div class="iso-cube cube-3" style="--size: 96px;">
            <div class="face front"></div>
            <div class="face back"></div>
            <div class="face right"></div>
            <div class="face left"></div>
            <div class="face top"></div>
            <div class="face bottom"></div>
          </div>

          <!-- Cube 4: Extra Large -->
          <div class="iso-cube cube-4" style="--size: 120px;">
            <div class="face front"></div>
            <div class="face back"></div>
            <div class="face right"></div>
            <div class="face left"></div>
            <div class="face top"></div>
            <div class="face bottom"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .isometric-scene {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    transform: rotateX(0deg) rotateY(0deg);
    perspective: 800px;
    transform-style: preserve-3d;
    scale: 0.75;
    transform-origin: center;
  }

  @media (min-width: 640px) {
    .isometric-scene {
      scale: 0.85;
    }
  }

  @media (min-width: 1024px) {
    .isometric-scene {
      scale: 1;
    }
  }

  .iso-cube {
    position: relative;
    width: var(--size);
    height: var(--size);
    transform-style: preserve-3d;
    transform: rotateX(30deg) rotateY(-45deg);
  }

  .face {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 1.5px solid;
    background: transparent;
  }

  .face.front  { transform: translateZ(calc(var(--size) / 2)); }
  .face.back   { transform: translateZ(calc(var(--size) / -2)) rotateY(180deg); }
  .face.right  { transform: rotateY(90deg) translateZ(calc(var(--size) / 2)); }
  .face.left   { transform: rotateY(-90deg) translateZ(calc(var(--size) / 2)); }
  .face.top    { transform: rotateX(90deg) translateZ(calc(var(--size) / 2)); }
  .face.bottom { transform: rotateX(-90deg) translateZ(calc(var(--size) / 2)); }

  .iso-cube:nth-child(1) .face {
    border-color: var(--color-brand-500);
  }

  .iso-cube:nth-child(2) .face {
    border-color: var(--color-brand-400);
  }

  .iso-cube:nth-child(3) .face {
    border-color: var(--color-surface-400);
  }

  .iso-cube:nth-child(4) .face {
    border-color: var(--color-surface-300);
  }

  /* Cube sizes and spacing */
  .cube-1 {
    margin-right: -10px;
    z-index: 3;
  }

  .cube-2 {
    margin-right: -15px;
    z-index: 2;
  }

  .cube-3 {
    z-index: 1;
  }

  .cube-4 {
    z-index: 0;
  }
</style>