---
const technologies = [
  // Model providers
  { name: "OpenAI", slug: null, logo: "/logos/openai.svg" },
  { name: "Anthropic", slug: "anthropic", logo: null },
  { name: "Qwen", slug: "qwen", logo: null },
  { name: "AWS", slug: null, logo: "/logos/aws.svg" },
  // Cloud & compute
  { name: "Google Cloud", slug: "googlecloud", logo: null },
  { name: "Modal", slug: "modal", logo: null },
  { name: "LangChain", slug: "langchain", logo: null },
  { name: "LangGraph", slug: "langgraph", logo: null },
  // Serving & data
  { name: "vLLM", slug: "vllm", logo: null },
  { name: "Milvus", slug: "milvus", logo: null },
  { name: "MLflow", slug: "mlflow", logo: null },
  { name: "Databricks", slug: "databricks", logo: null },
  // Platform & infra
  { name: "Hugging Face", slug: "huggingface", logo: null },
  { name: "Docker", slug: "docker", logo: null },
  { name: "Kubernetes", slug: "kubernetes", logo: null },
  { name: "Redis", slug: "redis", logo: null },
];
---

<section id="technologies" class="bg-ivory pt-16 pb-20 sm:pt-20 sm:pb-24 lg:pt-24 lg:pb-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mb-12 sm:mb-16">
      <p class="text-xs font-medium text-brand-600 uppercase tracking-wider mb-3">Technologies</p>
      <h2 class="text-2xl sm:text-3xl font-semibold text-surface-900 tracking-tight">
        Our technology stack
      </h2>
      <p class="mt-4 text-base text-surface-600 leading-relaxed">
        We build on platforms that scale with your data. The stack prioritizes open-source models, vector search, and production-grade orchestration. You get the flexibility of open source with the reliability of cloud infrastructure.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      {technologies.map((tech) => (
        <div class="flex flex-col items-center text-center gap-2 tech-item">
          <div class="tech-icon w-8 h-8 relative">
            <img
              src={tech.logo ?? `https://cdn.simpleicons.org/${tech.slug}`}
              alt={tech.name}
              class="w-8 h-8 object-contain transition-opacity duration-300"
              style="filter: grayscale(1) brightness(0.4); position: absolute; top: 0; left: 0;"
            />
            <img
              src={tech.logo ?? `https://cdn.simpleicons.org/${tech.slug}`}
              alt={tech.name}
              class="w-8 h-8 object-contain transition-opacity duration-300 tech-color"
              style="position: absolute; top: 0; left: 0; opacity: 0;"
            />
          </div>
          <p class="text-sm font-semibold text-surface-900">{tech.name}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll(".tech-item").forEach((item) => {
    const colorImg = item.querySelector(".tech-color");
    const grayImg = item.querySelector(".tech-icon img:first-child");

    item.addEventListener("mouseenter", () => {
      grayImg.style.opacity = "0";
      colorImg.style.opacity = "1";
    });

    item.addEventListener("mouseleave", () => {
      grayImg.style.opacity = "1";
      colorImg.style.opacity = "0";
    });
  });
</script>