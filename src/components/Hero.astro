<section class="bg-ivory pt-20 pb-16 sm:pt-28 sm:pb-20 lg:pt-32 lg:pb-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <p class="text-sm text-surface-500 mb-6">
          AI &middot; Machine Learning &middot; Data Engineering
        </p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-semibold text-surface-900 leading-tight tracking-tight">
          We build AI systems for production.
        </h1>
        <p class="mt-6 text-lg text-surface-600 leading-relaxed max-w-xl">
          <span class="font-brand font-bold">Hoja</span> designs and ships machine learning models and custom software. We turn your data into prediction models and applications your team uses.
        </p>
        <div class="mt-8 flex gap-4">
          <a href="#contact" class="text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 px-5 py-2.5 rounded-md transition-colors">Get in Touch</a>
          <a href="#services" class="text-sm font-medium text-surface-700 hover:text-surface-900 px-5 py-2.5 rounded-md transition-colors border border-surface-300 hover:border-surface-400">Our Services</a>
        </div>
      </div>

      <div class="flex items-center justify-center">
        <canvas id="leaf" width="400" height="400" class="w-64 h-64 sm:w-72 sm:h-72 lg:w-80 lg:h-80"></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  const c = document.getElementById("leaf") as HTMLCanvasElement | null;
  if (c) {
    const ctx = c.getContext("2d")!;
    const W = c.width;
    const H = c.height;
    const greens = ["#3a741c", "#4d9622", "#6bb82d", "#8fd042"];
    let t = 0;

    const draw = (
      x: number,
      y: number,
      angle: number,
      len: number,
      width: number,
      depth: number,
    ) => {
      if (depth <= 0 || len < 5) {
        ctx.fillStyle = "#8fd042";
        ctx.globalAlpha = 0.85;
        ctx.beginPath();
        ctx.arc(x, y, 2.4, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
        return;
      }
      const sway = Math.sin(t + depth * 0.6) * 0.045;
      const a = angle + sway;
      const x2 = x + Math.cos(a) * len;
      const y2 = y + Math.sin(a) * len;
      const ci = Math.max(0, Math.min(3, 3 - Math.floor(depth / 3)));
      ctx.strokeStyle = greens[ci];
      ctx.lineWidth = width;
      ctx.lineCap = "round";
      ctx.beginPath();
      ctx.moveTo(x, y);
      ctx.lineTo(x2, y2);
      ctx.stroke();
      draw(x2, y2, a - 0.34, len * 0.75, width * 0.7, depth - 1);
      draw(x2, y2, a + 0.46, len * 0.7, width * 0.7, depth - 1);
    };

    const frame = () => {
      t += 0.012;
      ctx.clearRect(0, 0, W, H);
      draw(W / 2, H * 0.96, -Math.PI / 2, 74, 5, 8);
      requestAnimationFrame(frame);
    };
    frame();
  }
</script>
