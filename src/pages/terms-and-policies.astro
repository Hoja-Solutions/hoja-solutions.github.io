---
import BaseLayout from "../layouts/BaseLayout.astro";
import Terms from "../components/Terms.astro";

const base = import.meta.env.BASE_URL;
const alt = `${base}es/terms-and-policies`;
---

<BaseLayout
  lang="en"
  alt={alt}
  title="Terms and Policies — Hoja"
  description="Engagement terms, data privacy, AI limitations, and open-source policies."
>
  <Terms lang="en" alt={alt} />
</BaseLayout>
