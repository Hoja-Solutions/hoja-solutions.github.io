---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Landing from "../../components/Landing.astro";
import { getUi } from "../../i18n/ui";

const lang = "es";
const t = getUi(lang);
const base = import.meta.env.BASE_URL;
const alt = base;

const ogImage = Astro.site
  ? new URL(`${base}og-home.png`, Astro.site).href
  : undefined;
const logo = Astro.site
  ? new URL(`${base}apple-touch-icon.png`, Astro.site).href
  : undefined;

const org = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Hoja",
  url: Astro.site?.href ?? "https://hoja-solutions.github.io",
  description: t.meta.homeDescription,
  ...(logo ? { logo } : {}),
  sameAs: [
    "https://linkedin.com/company/hoja-solutions",
    "https://github.com/hoja-solutions",
    "https://huggingface.co/hoja-solutions",
  ],
};
---

<BaseLayout
  lang={lang}
  alt={alt}
  title={t.meta.homeTitle}
  description={t.meta.homeDescription}
  image={ogImage}
  jsonLd={org}
>
  <Landing lang={lang} alt={alt} />
</BaseLayout>
