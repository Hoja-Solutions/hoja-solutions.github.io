---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import BlogIndexBody from "../../../../components/BlogIndexBody.astro";
import { getPosts, allTags, tagSlug } from "../../../../lib/posts";
import { getUi } from "../../../../i18n/ui";

export async function getStaticPaths() {
  const posts = await getPosts("es");
  return allTags(posts).map((tag) => ({
    params: { tag: tagSlug(tag) },
    props: { tag, posts: posts.filter((p) => (p.data.tags ?? []).includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
const lang = "es" as const;
const t = getUi(lang);
const base = import.meta.env.BASE_URL;
const alt = `${base}blog`;
---

<BaseLayout
  lang={lang}
  alt={alt}
  title={`${t.blog.tagged} ${tag} — Hoja`}
  description={`${t.blog.metaDescription}`}
>
  <BlogIndexBody lang={lang} alt={alt} posts={posts} tag={tag} />
</BaseLayout>
