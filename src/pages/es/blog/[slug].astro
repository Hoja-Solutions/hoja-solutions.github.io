---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPostBody from "../../../components/BlogPostBody.astro";
import { getPosts, slugOf } from "../../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPosts("es");
  return posts.map((post, i) => ({
    params: { slug: slugOf(post) },
    props: {
      post,
      older: posts[i + 1] ?? null,
      newer: posts[i - 1] ?? null,
      related: posts
        .filter(
          (p) =>
            p.id !== post.id &&
            (p.data.tags ?? []).some((t) => (post.data.tags ?? []).includes(t)),
        )
        .slice(0, 3),
    },
  }));
}

const { post, older, newer, related } = Astro.props;
const lang = "es" as const;
const base = import.meta.env.BASE_URL;
const slug = slugOf(post);
const alt = `${base}blog/${slug}`;

const ogImage = Astro.site
  ? new URL(`${base}es/og/${slug}.png`, Astro.site).href
  : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  inLanguage: "es",
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  author: { "@type": "Organization", name: "Hoja" },
  publisher: { "@type": "Organization", name: "Hoja" },
  keywords: (post.data.tags ?? []).join(", "),
  ...(ogImage ? { image: ogImage } : {}),
  ...(Astro.site
    ? { mainEntityOfPage: new URL(`${base}es/blog/${slug}/`, Astro.site).href }
    : {}),
};
---

<BaseLayout
  lang={lang}
  alt={alt}
  title={`${post.data.title} — Hoja`}
  description={post.data.description}
  date={post.data.date}
  image={ogImage}
  ogType="article"
  jsonLd={jsonLd}
>
  <BlogPostBody lang={lang} alt={alt} post={post} older={older} newer={newer} related={related} />
</BaseLayout>
