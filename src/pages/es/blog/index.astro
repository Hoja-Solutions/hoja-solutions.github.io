---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogIndexBody from "../../../components/BlogIndexBody.astro";
import { getPosts, allTags } from "../../../lib/posts";
import { getUi } from "../../../i18n/ui";

const lang = "es" as const;
const t = getUi(lang);
const posts = await getPosts(lang);
const tags = allTags(posts);
const base = import.meta.env.BASE_URL;
const alt = `${base}blog`;
---

<BaseLayout lang={lang} alt={alt} title={t.blog.metaTitle} description={t.blog.metaDescription}>
  <BlogIndexBody lang={lang} alt={alt} posts={posts} tags={tags} />
</BaseLayout>
