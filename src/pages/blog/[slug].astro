---
import BlogLayout from "../../layouts/BlogLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";
import { generatePortrait } from "../../lib/portrait";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Deterministic constellation illustration, shared with the Open Graph image.
const { points, lines } = generatePortrait(post.body);

// Absolute URL to the generated preview image for social cards.
const base = import.meta.env.BASE_URL;
const ogImage = Astro.site
  ? new URL(`${base}og/${post.id}.png`, Astro.site).href
  : undefined;
---

<BlogLayout
  title={`${post.data.title} — Hoja`}
  description={post.data.description}
  date={post.data.date}
  image={ogImage}
>
  <div class="flex flex-col min-h-screen">
    <Navbar />
    <main class="flex-1">
      <article class="bg-ivory pt-16 pb-20 sm:pt-20 sm:pb-24">
        <div class="max-w-3xl mx-auto px-6 lg:px-8">
          <div class="mb-8">
            <a href="/blog" class="text-xs text-brand-600 hover:text-brand-700 font-medium">
              ← Back to blog
            </a>
            <!-- Portrait Illustration -->
            <div class="illustration-container mt-3 mb-4">
              <svg viewBox="0 0 300 100" class="illustration-svg" preserveAspectRatio="none" width="100%" height="100%">
                {lines.map((l) => (
                  <line x1={`${points[l.a].x}%`} y1={`${points[l.a].y}%`} x2={`${points[l.b].x}%`} y2={`${points[l.b].y}%`} stroke={l.color} stroke-width="0.5" stroke-opacity={l.opacity} />
                ))}
                {points.map((p) => (
                  <circle cx={`${p.x}%`} cy={`${p.y}%`} r="1.5" fill={p.color} />
                ))}
              </svg>
            </div>

            <h1 class="text-2xl sm:text-3xl font-semibold text-surface-900 tracking-tight">
              {post.data.title}
            </h1>
            <div class="flex items-baseline gap-3 mt-3">
              <time class="text-xs text-surface-500 font-brand tabular-nums">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                  timeZone: "UTC",
                })}
              </time>
              {post.data.tags?.length && (
                <span class="text-xs text-surface-400">
                  · {post.data.tags.join(", ")}
                </span>
              )}
            </div>
            <p class="text-sm text-surface-500 leading-relaxed mt-3 border-l-2 border-brand-500 pl-3">
              {post.data.description}
            </p>
          </div>

<div class="prose">
            <Content />
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </div>
</BlogLayout>

<style>
  .illustration-container {
    width: 100%;
    aspect-ratio: 3 / 1;
    background: var(--color-ivory-dark);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-surface-200);
  }

  .illustration-svg {
    width: 100%;
    height: 100%;
  }
</style>