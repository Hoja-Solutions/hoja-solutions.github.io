---
import BlogLayout from "../../layouts/BlogLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Generate a deterministic seed from post content
const content = post.body;
const hash = content.split("").reduce((acc, char) => {
  const charCode = char.charCodeAt(0);
  return ((acc << 5) - acc + charCode) | 0;
}, 0);

let s = Math.abs(hash);
const next = () => {
  s = (s * 16807 + 11) % 2147483647;
  return s / 2147483647;
};
const rand = (min, max) => min + next() * (max - min);

const colors = [
  "#6bb82d",
  "#4d9622",
  "#b5ada0",
  "#908779",
  "#8fd042",
];

// Grid-based constellation: percentage coordinates fill any container shape
const cols = 12 + Math.floor(rand(0, 5));
const rows = 4 + Math.floor(rand(0, 2));
const cellW = 100 / cols;
const cellH = 100 / rows;
const points = [];

for (let row = 0; row < rows; row++) {
  for (let col = 0; col < cols; col++) {
    const jx = rand(-cellW * 0.4, cellW * 0.4);
    const jy = rand(-cellH * 0.4, cellH * 0.4);
    const x = Math.max(2, Math.min(98, cellW * (col + 0.5) + jx));
    const y = Math.max(2, Math.min(98, cellH * (row + 0.5) + jy));
    points.push({ x, y, color: colors[Math.floor(rand(0, colors.length))] });
  }
}

// Connect each point to its nearest neighbors
const lines = [];
points.forEach((p, i) => {
  const dists = points.map((q, j) => ({
    j,
    d: Math.sqrt((p.x - q.x) ** 2 + (p.y - q.y) ** 2),
  }));
  dists.sort((a, b) => a.d - b.d);
  const numConn = 2 + Math.floor(rand(0, 2));
  for (let k = 0; k < Math.min(numConn, dists.length - 1); k++) {
    if (dists[k].j > i) {
      lines.push({
        a: i,
        b: dists[k].j,
        color: colors[Math.floor(rand(0, colors.length))],
        opacity: rand(0.1, 0.35),
      });
    }
  }
});
---

<BlogLayout
  title={`${post.data.title} — Hoja`}
  description={post.data.description}
  date={post.data.date}
>
  <div class="flex flex-col min-h-screen">
    <Navbar />
    <main class="flex-1">
      <article class="bg-ivory pt-16 pb-20 sm:pt-20 sm:pb-24">
        <div class="max-w-3xl mx-auto px-6 lg:px-8">
          <div class="mb-8">
            <a href="/blog" class="text-xs text-brand-600 hover:text-brand-700 font-medium">
              ← Back to blog
            </a>
            <!-- Portrait Illustration -->
            <div class="illustration-container mt-3 mb-4">
              <svg viewBox="0 0 300 100" class="illustration-svg" preserveAspectRatio="none" width="100%" height="100%">
                {lines.map((l) => (
                  <line x1={`${points[l.a].x}%`} y1={`${points[l.a].y}%`} x2={`${points[l.b].x}%`} y2={`${points[l.b].y}%`} stroke={l.color} stroke-width="0.5" stroke-opacity={l.opacity} />
                ))}
                {points.map((p) => (
                  <circle cx={`${p.x}%`} cy={`${p.y}%`} r="1.5" fill={p.color} />
                ))}
              </svg>
            </div>

            <h1 class="text-2xl sm:text-3xl font-semibold text-surface-900 tracking-tight">
              {post.data.title}
            </h1>
            <div class="flex items-baseline gap-3 mt-3">
              <time class="text-xs text-surface-500 font-brand tabular-nums">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              {post.data.tags?.length && (
                <span class="text-xs text-surface-400">
                  · {post.data.tags.join(", ")}
                </span>
              )}
            </div>
            <p class="text-base text-surface-600 leading-relaxed mt-3">
              {post.data.description}
            </p>
          </div>

<div class="prose">
            <Content />
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </div>
</BlogLayout>

<style>
  .illustration-container {
    width: 100%;
    aspect-ratio: 3 / 1;
    background: var(--color-ivory-dark);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-surface-200);
  }

  .illustration-svg {
    width: 100%;
    height: 100%;
  }
</style>