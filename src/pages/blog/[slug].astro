---
import BlogLayout from "../../layouts/BlogLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout
  title={`${post.data.title} — Hoja`}
  description={post.data.description}
  date={post.data.date}
>
  <div class="flex flex-col min-h-screen">
    <Navbar />
    <main class="flex-1">
      <article class="bg-ivory pt-16 pb-20 sm:pt-20 sm:pb-24">
        <div class="max-w-3xl mx-auto px-6 lg:px-8">
          <div class="mb-8">
            <a href="/blog" class="text-xs text-brand-600 hover:text-brand-700 font-medium">
              ← Back to blog
            </a>
            <h1 class="text-2xl sm:text-3xl font-semibold text-surface-900 tracking-tight mt-3">
              {post.data.title}
            </h1>
            <div class="flex items-baseline gap-3 mt-3">
              <time class="text-xs text-surface-500 font-brand tabular-nums">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              {post.data.tags?.length && (
                <span class="text-xs text-surface-400">
                  · {post.data.tags.join(", ")}
                </span>
              )}
            </div>
            <p class="text-base text-surface-600 leading-relaxed mt-3">
              {post.data.description}
            </p>
          </div>

          <div class="prose">
            <Content />
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </div>
</BlogLayout>